{
  "name": "diktate",
  "version": "0.1.0-mvp",
  "description": "Privacy-first voice dictation for Windows",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && tsc -p tsconfig.settings.json && copy /y src\\*.html dist\\ && copy /y src\\*.css dist\\ && copy /y src\\*.js dist\\ && xcopy /E /I /Y src\\locales dist\\locales && electron . --dev",
    "start": "electron .",
    "build": "tsc && tsc -p tsconfig.settings.json && copy /y src\\*.html dist\\ && copy /y src\\*.css dist\\ && copy /y src\\*.js dist\\ && xcopy /E /I /Y src\\locales dist\\locales && electron .",
    "dist": "pnpm run package-python && electron-builder",
    "package-python": "cd python && build_backend.bat",
    "test": "node tests/smoke-test.cjs && python -m pytest tests/ python/ -v --tb=short",
    "test:unit": "python -m pytest tests/unit/ -v",
    "test:integration": "python -m pytest tests/integration/ -v",
    "test:all": "node tests/smoke-test.cjs && python -m pytest tests/ python/ -v",
    "test:ci": "python -m pytest tests/ -v --tb=short -x -m \"not requires_gpu and not requires_audio and not requires_ollama\"",
    "test:hardware": "python -m pytest tests/ -v -m \"requires_gpu or requires_audio or requires_ollama\"",
    "test:ts": "vitest run",
    "test:ts:watch": "vitest",
    "test:ts:ui": "vitest --ui",
    "test:ts:coverage": "vitest run --coverage",
    "i18n:validate": "node scripts/validateTranslations.js",
    "lint": "eslint \"src/**/*.{ts,js}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,js,html,css}\"",
    "docs:python": "python python/tools/generate_docs.py",
    "docs:ts": "typedoc --entryPointStrategy expand src/ --out docs/api/typescript",
    "docs": "pnpm run docs:python && pnpm run docs:ts",
    "prepare": "husky install"
  },
  "keywords": [
    "dictation",
    "voice",
    "transcription",
    "privacy"
  ],
  "author": "dIKtate Contributors",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.17.15",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^20.5.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.16",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.py": [
      "ruff format",
      "ruff check --fix"
    ]
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "electron-store": "^8.2.0",
    "i18next": "^25.8.4",
    "i18next-fs-backend": "^2.6.1",
    "i18next-icu": "^2.4.3",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.diktate.app",
    "productName": "dIKtate",
    "files": [
      "dist/**/*",
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "icon": "assets/icon.png",
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "python/dist/diktate-engine.exe",
        "to": "bin/diktate-engine.exe"
      },
      {
        "from": "src/locales",
        "to": "locales"
      }
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "tar": "^7.5.4",
      "lodash": "^4.17.23",
      "tar@<7.5.7": ">=7.5.7",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "markdown-it@>=13.0.0 <14.1.1": ">=14.1.1",
      "tar@<7.5.8": ">=7.5.8",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=5.0.0 <5.1.7": ">=5.1.7",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=10.0.0 <10.2.1": ">=10.2.1",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "minimatch@<3.1.4": ">=3.1.4",
"@tootallnate/once@<3.0.1": ">=3.0.1",
      "tar@<=7.5.9": ">=7.5.10",
      "tar@<=7.5.10": ">=7.5.11",
      "flatted@<3.4.0": ">=3.4.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "happy-dom@<20.8.9": ">=20.8.9",
      "happy-dom@>=15.10.0 <=20.8.7": ">=20.8.8",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "@xmldom/xmldom@<0.8.12": ">=0.8.12",
      "electron@<38.8.6": ">=38.8.6",
      "electron@<39.8.1": ">=39.8.1",
      "electron@>=33.0.0-alpha.1 <39.8.5": ">=39.8.5",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "electron@<39.8.5": ">=39.8.5"
    }
  }
}